generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  user_id    Int      @id @default(autoincrement())
  full_name  String
  phone      String
  email      String   @unique
  password   String
  role       String
  created_at DateTime @default(now())

  vaccinations Vaccination[]
  alerts       Alert[]
}

model Farm {
  farm_id    Int      @id @default(autoincrement())
  farm_name  String
  location   String
  created_at DateTime @default(now())

  animals   Animal[]
  alerts    Alert[]
  schedules VaccinationSchedule[]
}

model Animal {
  animal_id   Int      @id @default(autoincrement())
  nickname    String?
  animal_type String
  age         Int
  gender      String
  status      String   @default("Active")
  farm_id     Int
  created_at  DateTime @default(now())

  farm         Farm          @relation(fields: [farm_id], references: [farm_id])
  vaccinations Vaccination[]
  alerts       Alert[]
}

model Vaccine {
  vaccine_id                Int      @id @default(autoincrement())
  vaccine_name              String
  description               String?
  validity_period_days      Int
  recommended_interval_days Int
  created_at                DateTime @default(now())

  stocks       VaccineStock[]
  vaccinations Vaccination[]
  schedules    VaccinationSchedule[]
}

model Supplier {
  supplier_id   Int      @id @default(autoincrement())
  supplier_name String
  phone         String
  address       String
  created_at    DateTime @default(now())

  stocks VaccineStock[]
}

model VaccineStock {
  stock_id           Int      @id @default(autoincrement())
  vaccine_id         Int
  supplier_id        Int
  batch_number       String?
  quantity_purchased Int
  quantity_remaining Int
  purchase_price     Float
  purchase_date      DateTime
  expiry_date        DateTime
  created_at         DateTime @default(now())

  vaccine  Vaccine  @relation(fields: [vaccine_id], references: [vaccine_id])
  supplier Supplier @relation(fields: [supplier_id], references: [supplier_id])

  vaccinations Vaccination[]
}

model Vaccination {
  vaccination_id    Int      @id @default(autoincrement())
  animal_id         Int
  vaccine_id        Int
  administered_by   Int
  stock_id          Int
  date_administered DateTime
  next_due_date     DateTime
  created_at        DateTime @default(now())

  animal  Animal       @relation(fields: [animal_id], references: [animal_id])
  vaccine Vaccine      @relation(fields: [vaccine_id], references: [vaccine_id])
  user    User         @relation(fields: [administered_by], references: [user_id])
  stock   VaccineStock @relation(fields: [stock_id], references: [stock_id])
}

model VaccinationSchedule {
  schedule_id    Int      @id @default(autoincrement())
  vaccine_id     Int
  farm_id        Int?
  schedule_type  String
  scheduled_date DateTime
  created_at     DateTime @default(now())

  vaccine Vaccine @relation(fields: [vaccine_id], references: [vaccine_id])
  farm    Farm?   @relation(fields: [farm_id], references: [farm_id])
}

model Alert {
  alert_id   Int      @id @default(autoincrement())
  animal_id  Int
  farm_id    Int
  user_id    Int // reported_by
  symptoms   String
  status     String   @default("Pending")
  created_at DateTime @default(now())

  animal Animal @relation(fields: [animal_id], references: [animal_id])
  farm   Farm   @relation(fields: [farm_id], references: [farm_id])
  user   User   @relation(fields: [user_id], references: [user_id])
}
